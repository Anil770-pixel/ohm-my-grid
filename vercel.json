{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "installCommand": "npm install",
      "buildCommand": "npm run build",
      "outputDirectory": "dist"
    },
    "backend": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/api",
      "installCommand": "pip install -r requirements.txt"
    }
  }
}
